{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"isolatedModules": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"noEmit": true,
		"lib": ["DOM", "ES2018", "ES2020"]
	},
	"include": ["main.ts"]
}
